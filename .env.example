# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Storage — 默认 SQLite + ChromaDB（零服务，无需 Docker）
# MySQL（设 USE_MYSQL=true 启用）
# USE_MYSQL=false
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=mcmod
# MYSQL_PASSWORD=mcmod_pwd
# MYSQL_DB=mcmod_qa
# 如需 Qdrant: 设 USE_QDRANT=true 并取消下面注释
# USE_QDRANT=false
# QDRANT_HOST=127.0.0.1
# QDRANT_PORT=6333
# QDRANT_COLLECTION=mcmod_v1
# ChromaDB 路径（默认无需改）
# CHROMA_PATH=data/chroma
# SQLite 路径（默认无需改）
# SQLITE_PATH=data/minemate.db

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# Storage — 自定义路径，避免占用 C 盘
# DATA_DIR=./data            # 项目数据目录
# HF_HOME=D:/hf_cache        # HuggingFace 模型缓存
# HF_ENDPOINT=https://hf-mirror.com  # 国内镜像

# 代理池（可选 — IP 被封时才需要，获取方式见 README）
# PROXY_API_URL=https://dps.kdlapi.com/api/getdps/?...
# PROXY_USER=your_username
# PROXY_PASS=your_password

# Pipeline
CRAWL_DELAY_SECONDS=1.5
TUTORIAL_LIMIT_PER_MOD=30
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=8
SIMILARITY_THRESHOLD=0.5

# App
LOG_LEVEL=INFO
LOG_DIR=data/logs

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mcmod
MYSQL_PASSWORD=mcmod_pwd
MYSQL_DB=mcmod_qa

# Qdrant
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=mcmod_v1

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# Pipeline
CRAWL_DELAY_SECONDS=1.5
TUTORIAL_LIMIT_PER_MOD=30
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=8
SIMILARITY_THRESHOLD=0.5

# App
LOG_LEVEL=INFO
LOG_DIR=data/logs
